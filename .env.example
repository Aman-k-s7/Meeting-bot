# --- LLM Settings ---
LLM_PROVIDER=gemini  # 'gemini' or 'groq'
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Sheets Settings ---
PUSH_TO_SHEETS=true
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
SHEET_ID=your_google_sheet_id_here

# Manager Settings
MANAGER1_NAME="Aman"
MANAGER2_NAME="Anshika"
MANAGER3_NAME="Alice"

# --- Notion Settings (Optional) ---
PUSH_TO_NOTION=false
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here

# --- Webhook Settings ---
READAI_SIGNING_KEY=your_readai_signing_key_here

# --- Email (SMTP) Settings ---
SEND_IMMEDIATE_EMAILS=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_NAME="Meeting Bot"
TEAM_DIGEST_RECIPIENTS=team1@example.com,team2@example.com
